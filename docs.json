{
  "$schema": "https://mintlify.com/docs.json",
  "name": "gitsw",
  "theme": "aspen",
  "colors": {
    "primary": "#FF6B35",
    "light": "#FFB4A2",
    "dark": "#D9534F"
  },
  "navbar": {
    "primary": {
      "type": "github",
      "href": "https://github.com/yigiterdev/git-switch"
    }
  },
  "footer": {
    "socials": {
