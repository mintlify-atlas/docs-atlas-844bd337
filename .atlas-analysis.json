  "keyFeatures": [
    "Interactive branch picker with fuzzy search",
    "Automatic stash management on branch switch",
    "Auto-unstash when returning to branches",
    "Package manager dependency sync detection",
    "Recent branches tracking",
    "Remote branch tracking support"
  ],
  "publicApiSurface": [
    "gitsw [BRANCH] - Switch to branch",
    "gitsw -l, --list - List branches with stashes",
    "gitsw -r, --recent - Show recent branches",
    "gitsw -s, --status - Show current status",
    "gitsw -d, --delete <BRANCH> - Delete branch",
    "gitsw -t, --track <REMOTE/BRANCH> - Track remote branch",
    "gitsw -c, --create - Create branch if doesn't exist",
    "gitsw -p, --pull - Pull after switching",
    "gitsw --no-stash - Skip automatic stash",
    "gitsw --no-install - Skip automatic package install"
  ]
